NGINX_VERSION=1.27-alpine
GATEWAY_PORT=8000

PHP_VERSION=8.3

MYSQL_VERSION=8.4
MYSQL_PORT=3306
MYSQL_DATABASE=blog
MYSQL_USER=blog
MYSQL_PASSWORD=secret
MYSQL_ROOT_PASSWORD=root_secret

AUTH_MYSQL_PORT=3307
AUTH_MYSQL_DATABASE=auth
AUTH_MYSQL_USER=auth
AUTH_MYSQL_PASSWORD=secret
AUTH_MYSQL_ROOT_PASSWORD=root_secret

ADMIN_MYSQL_PORT=3308
ADMIN_MYSQL_DATABASE=admin
ADMIN_MYSQL_USER=admin
ADMIN_MYSQL_PASSWORD=secret
ADMIN_MYSQL_ROOT_PASSWORD=root_secret

RABBITMQ_VERSION=3-management
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_DEFAULT_USER=blog
RABBITMQ_DEFAULT_PASS=secret
RABBITMQ_DEFAULT_VHOST=blog

ELASTICSEARCH_VERSION=8.15.3
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_JAVA_OPTS=-Xms512m -Xmx512m
