APP_NAME=BlogService
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000/api/blog

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=blog
DB_USERNAME=blog
DB_PASSWORD=secret

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

ELASTICSEARCH_HOST=http://elasticsearch:9200
ELASTICSEARCH_POSTS_INDEX=blog_posts
ELASTICSEARCH_TIMEOUT=10
AUTH_SERVICE_URL=http://auth-nginx
AUTH_SERVICE_TIMEOUT=5
AUTH_SERVICE_RETRIES=1
AUTH_SERVICE_CACHE_TTL=60

RABBITMQ_ENABLED=true
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=blog
RABBITMQ_PASSWORD=secret
RABBITMQ_VHOST=blog
RABBITMQ_EXCHANGE=domain.events
RABBITMQ_RETRY_EXCHANGE=domain.events.retry
RABBITMQ_FAILED_EXCHANGE=domain.events.failed
RABBITMQ_RETRY_TTL_MS=10000
RABBITMQ_MAX_ATTEMPTS=3
RABBITMQ_SEARCH_INDEXER_QUEUE=blog.search.indexer
RABBITMQ_SEARCH_INDEXER_RETRY_QUEUE=blog.search.indexer.retry
RABBITMQ_SEARCH_INDEXER_FAILED_QUEUE=blog.search.indexer.failed

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
